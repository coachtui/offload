# The Hub - Environment Variables Template
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000
ML_SERVICE_PORT=8000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hub_user
POSTGRES_PASSWORD=hub_dev_password
POSTGRES_DB=thehub_dev
DATABASE_URL=postgresql://hub_user:hub_dev_password@localhost:5432/thehub_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# OpenAI (for Whisper and Embeddings)
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum
ENCRYPTION_ALGORITHM=aes-256-gcm

# Object Storage (S3-compatible: MinIO for dev, AWS S3 for prod)
# For local development with Docker MinIO:
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=thehub-dev
S3_REGION=us-east-1

# For Railway/Production with AWS S3:
# S3_ENDPOINT=s3.amazonaws.com
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# Privacy Settings
ENCRYPT_LOCATION_BY_DEFAULT=false
ENCRYPT_METADATA_BY_DEFAULT=false
AUDIO_RETENTION_DAYS=7

# ML Service
ML_SERVICE_URL=http://localhost:8000
USE_LOCAL_WHISPER=false
WHISPER_MODEL_SIZE=base

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info
