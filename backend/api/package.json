{
  "name": "@thehub/api",
  "version": "0.1.0",
  "description": "The Hub API Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmitOnError false || true",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "node --require tsx/cjs ./node_modules/.bin/node-pg-migrate up",
    "migrate:down": "node --require tsx/cjs ./node_modules/.bin/node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:status": "node --require tsx/cjs ./node_modules/.bin/node-pg-migrate status",
    "db:setup": "npm run migrate",
    "generate-embeddings": "tsx src/scripts/generate-embeddings.ts"
  },
  "keywords": [
    "offload",
    "cognitive-inbox",
    "voice-notes",
    "knowledge-graph"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.6",
    "openai": "^6.16.0",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "weaviate-ts-client": "^2.2.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^6.2.2",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
