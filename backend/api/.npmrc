# Railway/Nixpacks builds run npm in production mode (NODE_ENV=production),
# which omits devDependencies. But the build step needs them (tsc/typescript,
# @types/*) to compile src -> dist. Force dev deps to be installed so the build
# is reproducible and not dependent on a warm node_modules layer cache.
# Runtime correctness is unaffected: `npm run start` only uses `dependencies`.
include=dev
